rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {
    
    // Check if the current user is an admin by looking up their UID in the admins collection
    function isAdmin() {
      return request.auth != null && firestore.exists(/databases/(default)/documents/admins/$(request.auth.uid));
    }

    match /images/{imageId} {
      // Anyone can view the images
      allow read: if true;
      // Only admins can upload/delete images
      allow write: if isAdmin();
    }
  }
}
